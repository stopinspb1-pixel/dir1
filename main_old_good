def read_values():
    """Читает все значения из файла (каждое с новой строки)."""
    try:
        with open(FILE_PATH, "r", encoding="utf-8") as f:
            return [line.strip() for line in f if line.strip()]
    except FileNotFoundError:
        # Возвращаем список дефолтных значений, но файл на диске пока не создаем
        return [f"default_{i}" for i in range(1, 11)]

