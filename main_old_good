@app.post("/set0")
async def set_zero():
    """
    Заменяет каждое значение в val.txt на '0',
    сохраняя количество строк.
    """
    # Проверяем, существовал ли файл физически до операции
    file_existed = os.path.exists(FILE_PATH)
    
    current_values = read_values()
    count = len(current_values)
    
    # Гарантируем, что каждая строка (включая последнюю) закончится символом \n
    content_to_write = "".join(["0\n" for _ in range(count)])

    try:
        # Атомарная запись: пишем во временный файл, затем заменяем им целевой.
        # Это исключает чтение «битого» файла другими запросами во время записи.
        dir_name = os.path.dirname(FILE_PATH)
        with tempfile.NamedTemporaryFile('w', dir=dir_name, delete=False, encoding='utf-8') as tf:
            tf.write(content_to_write)
            temp_name = tf.name
            
        os.replace(temp_name, FILE_PATH)
        
        message = (
            f"Все {count} значений заменены на 0" 
            if file_existed else 
            f"Файл отсутствовал. Создан новый файл с {count} нулями."
        )
        
        return JSONResponse(content={"status": "ok", "message": message})
        
    except Exception as e:
        return JSONResponse(
            status_code=500,
            content={"status": "error", "detail": str(e)}
        )

@app.post("/set1")
async def set_one():
    """
    Заменяет каждое значение в val.txt на '1',
    сохраняя количество строк.
    """
    file_existed = os.path.exists(FILE_PATH)
    current_values = read_values()
    count = len(current_values)
    
    # Гарантируем, что каждая строка закончится символом \n, но теперь пишем "1"
    content_to_write = "".join(["1\n" for _ in range(count)])

    try:
        dir_name = os.path.dirname(FILE_PATH)
        with tempfile.NamedTemporaryFile('w', dir=dir_name, delete=False, encoding='utf-8') as tf:
            tf.write(content_to_write)
            temp_name = tf.name
            
        os.replace(temp_name, FILE_PATH)
        
        message = (
            f"Все {count} значений заменены на 1" 
            if file_existed else 
            f"Файл отсутствовал. Создан новый файл с {count} единицами."
        )
        
        return JSONResponse(content={"status": "ok", "message": message})
        
    except Exception as e:
        return JSONResponse(
            status_code=500,
            content={"status": "error", "detail": str(e)}
        )

